&control
    calculation = 'scf'  
    restart_mode = 'from_scratch',
    pseudo_dir = '/home/sachs/software/q-e/Pseudofolder/nc-sr-04_pbesol_standard_upf',
    outdir='/home/sachs/software/q-e/tempdir/'
    prefix = 'gapPBEsol',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-6,
    verbosity   = 'high'
/
