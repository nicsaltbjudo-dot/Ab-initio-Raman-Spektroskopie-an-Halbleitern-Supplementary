&control
    calculation = 'vc-relax'  
    restart_mode = 'from_scratch',
    pseudo_dir = '/home/sachs/software/q-e/Pseudofolder/nc-sr-04_pbesol_standard_upf',
    outdir='/home/sachs/software/q-e/tempdir/'
    prefix = 'inasPBEsol',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-7,  
 /    
&SYSTEM
  ibrav = 2
  celldm(1)=11.429062779
  nat = 2
  ntyp = 2
  ecutwfc = 100
  ecutrho = 600
  occupations = 'fixed'
/
 &electrons
    diagonalization = 'cg',
    mixing_beta = 0.7,
    conv_thr = 1.0d-9,       
 /
 &ions
    ion_dynamics = 'bfgs',   
 /
 &cell
    cell_dynamics = 'bfgs',  
 /

ATOMIC_SPECIES
  In  114.81800  In.upf
  As   74.92100  As.upf

ATOMIC_POSITIONS {crystal}
  In  0.00000000  0.00000000  0.00000000 
  As  0.25000000  0.25000000  0.25000000
  
K_POINTS automatic

20 20 20 1 1 1 
