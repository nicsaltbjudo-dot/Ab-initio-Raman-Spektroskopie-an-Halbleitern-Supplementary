 &control
    calculation='scf'
    restart_mode='from_scratch',
    pseudo_dir = '/home/nico-sachs/source/q-e/Pseudofolder/nc-sr-04_pbe_standard_upf',
    prefix='gaasPBE',
    outdir='/home/nico-sachs/source/q-e/tempdir/'
    tprnfor = .true.
    tstress = .true.
    verbosity   = 'high'
 /    
 &system
  ibrav = 2
  celldm(1) = 10.8340382112  
  nat = 2
  ntyp = 2
  ecutwfc = 100
  ecutrho = 600
  occupations = 'fixed'
  nbnd = 16

/
 &electrons
    diagonalization='cg'
    mixing_beta = 0.7
 /

