&control
    calculation = 'vc-relax'  
    restart_mode = 'from_scratch',
    pseudo_dir = '/home/sachs/software/q-e/Pseudofolder/nc-sr-05_pbe_GGA_standard_upf',
    prefix = 'gaasGGA',
    outdir='/home/sachs/software/q-e/tempdir/',
    tprnfor = .true.,
    tstress = .true.,
    forc_conv_thr = 1.0d-5,  
 /    
 &system
    ibrav = 2,
    celldm(1) = 10.684,
    nat = 2,
    ntyp = 2,
    ecutwfc = 10,
    ecutrho = 600,          
    occupations = 'fixed',
 /
 &electrons
    diagonalization = 'cg',
    mixing_beta = 0.3,
    conv_thr = 1.0d-9,       
 /
 &ions
    ion_dynamics = 'bfgs',   
 /
 &cell
    cell_dynamics = 'bfgs',  
 /

ATOMIC_SPECIES
  Ga   69.72300  Ga.upf
  As   74.92100  As.upf
  
ATOMIC_POSITIONS crystal
Ga 0.00 0.00 0.00
As 0.25 0.25 0.25

K_POINTS automatic
12 12 12 0 0 0
